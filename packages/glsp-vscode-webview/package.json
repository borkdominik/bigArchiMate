{
  "name": "@big-archimate/glsp-vscode-webview",
  "version": "0.0.0",
  "private": true,
  "description": "bigArchiMate GLSP diagram client bundled for VS Code webviews",
  "homepage": "https://github.com/borkdominik/bigArchiMate",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/borkdominik/bigArchiMate"
  },
  "license": "AGPL-3.0-or-later",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "yarn compile && yarn bundle",
    "bundle": "webpack",
    "bundle:prod": "webpack --config ./webpack.prod.js",
    "clean": "rimraf lib tsconfig.tsbuildinfo dist",
    "compile": "tsc -b",
    "lint": "eslint -c ../../.eslintrc.js --ext .ts,.tsx ./src",
    "watch": "tsc -w"
  },
  "dependencies": {
    "@big-archimate/core": "0.0.0",
    "@big-archimate/glsp-client": "0.0.0",
    "@big-archimate/protocol": "0.0.0",
    "@eclipse-glsp/client": "2.7.0-next.25",
    "@eclipse-glsp/vscode-integration-webview": "2.7.0-next.5",
    "@vscode/codicons": "^0.0.44"
  },
  "devDependencies": {
    "css-loader": "^6.7.1",
    "process": "0.11.10",
    "source-map-loader": "^4.0.1",
    "style-loader": "^3.3.1",
    "ts-loader": "^9.4.2",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.1",
    "webpack-merge": "^5.9.0"
  }
}
